PIN_TOUCH = 17
PIN_MQ_DO = 22
PIN_DHT   = board.D27

GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)
GPIO.setup(PIN_TOUCH, GPIO.IN)
GPIO.setup(PIN_MQ_DO, GPIO.IN)

dht_device = adafruit_dht.DHT11(PIN_DHT)

app      = Flask(__name__)
socketio = SocketIO(app, cors_allowed_origins="*")

